#!/usr/bin/env bash
# devloop-guard — DevLoop 门禁执行引擎
# 用途: 门禁配置管理、硬/软门禁分离执行、软门禁待办清单输出
# 依赖: bash 4.x, grep, sed, awk
# 用法: devloop-guard <command> [args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
GUARD_CONFIG="$PROJECT_ROOT/.comet/guard-config.yaml"
STATE_FILE="$PROJECT_ROOT/.comet/loop-state.yaml"
SOFT_PENDING="$PROJECT_ROOT/.comet/gate-results/soft-gates-pending.json"
SOFT_GATES_DIR="$PROJECT_ROOT/.comet/gate-results"

# ─── 颜色输出 ────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
PASS_STR="${GREEN}[PASS]${NC}"
WARN_STR="${YELLOW}[WARN]${NC}"
FAIL_STR="${RED}[FAIL]${NC}"
INFO_STR="${CYAN}[INFO]${NC}"

# ─── 内部: 解析门禁配置 ──────────────────────────────────
# 从 YAML 中提取所有门禁的基本信息（id, name, type, stage）
# 返回: 每行一个门禁: id|name|type|stage|on_fail
parse_all_gates() {
  local config="${1:-$GUARD_CONFIG}"
  awk '
    BEGIN { id=""; name=""; type=""; stage=""; on_fail=""; in_gates=0; in_stage=0; current_stage="" }
    /^gates:/ { in_gates=1; next }
    !in_gates { next }
    /^  stage-/ { in_stage=1; split($1, a, ":"); current_stage=substr(a[1], 3); next }
    in_gates && in_stage && /^    - id:/ { split($0, a, ": "); id=a[2]; gsub(/"/, "", id) }
    in_gates && in_stage && /^      name:/ && id != "" { split($0, a, ": "); name=a[2]; gsub(/"/, "", name) }
    in_gates && in_stage && /^      type:/ && name != "" { split($0, a, ": "); type=a[2] }
    in_gates && in_stage && /^      stage:/ && type != "" { split($0, a, ": "); stage=a[2] }
    in_gates && in_stage && /^      on_fail:/ && stage != "" && type != "" {
      split($0, a, ": "); on_fail=a[2]
      if (on_fail !~ /\{/) {  # simple string value, not a map
        printf "%s|%s|%s|%s|%s\n", id, name, type, current_stage, on_fail
      }
      # Reset for next gate
      id=""; name=""; type=""; stage=""; on_fail=""
    }
    # Handle mixed type with on_fail map (skip if contains {)
    in_gates && in_stage && /^      on_fail:/ && stage != "" && type == "mixed" {
      # mixed gates have on_fail: with hard/soft sub-keys, keep the type as "mixed"
      id=""; name=""; type=""; stage=""; on_fail=""
    }
    /^  [a-z]/ && !/^  stage-/ { in_stage=0; current_stage="" }
  ' "$config" | sort -u
}

# 更精确的解析：遍历整个配置
parse_gates_full() {
  local config="${1:-$GUARD_CONFIG}"
  python3 -c "
import sys, re
with open('$config') as f:
    content = f.read()

# Simple YAML-like parsing for this specific structure
gates = []
current_stage = ''
for line in content.split('\n'):
    line_stripped = line.rstrip()
    # Stage header
    m = re.match(r'^  (stage-\d):', line)
    if m:
        current_stage = m.group(1)
        continue
    # Gate id
    m = re.match(r'^    - id: (\S+)', line)
    if m:
        gates.append({'id': m.group(1), 'stage': current_stage, 'name': '', 'type': '', 'on_fail': ''})
        continue
    if not gates:
        continue
    g = gates[-1]
    m = re.match(r'^      name: (.+)', line)
    if m:
        g['name'] = m.group(1).strip('\"')
        continue
    m = re.match(r'^      type: (\S+)', line)
    if m:
        g['type'] = m.group(1)
        continue
    m = re.match(r'^      on_fail: (\S+)', line)
    if m and g['type'] != 'mixed':
        g['on_fail'] = m.group(1)
        continue

for g in gates:
    if g['name']:
        print(f\"{g['id']}|{g['name']}|{g['type']}|{g['stage']}|{g.get('on_fail', '')}\")
" 2>/dev/null
}

# 使用 awk 精确解析门禁配置
parse_gates_simple() {
  local config="${1:-$GUARD_CONFIG}"
  awk '
    BEGIN { id=""; name=""; gtype=""; current_stage=""; gate_stage=""; on_fail=""; OFS="|" }
    /^  stage-/ {
      # 提取阶段名: "  stage-1:" → "stage-1"
      gsub(/^[[:space:]]+/, ""); gsub(/:$/, ""); current_stage=$1; next
    }
    /^    - id: G/ {
      # 输出前一个门禁
      if (id != "" && name != "" && gtype != "") {
        print id, name, gtype, gate_stage, on_fail
      }
      # 提取 id + 此时锁定 stage
      gsub(/^[[:space:]-]+id:[[:space:]]+/, ""); gsub(/[[:space:]]+$/, ""); id=$0
      gate_stage=current_stage
      name=""; gtype=""; on_fail=""; next
    }
    /^      name: / && id != "" {
      gsub(/^[[:space:]]+name:[[:space:]]+/, ""); gsub(/[[:space:]]+$/, ""); gsub(/^"/, ""); gsub(/"$/, ""); name=$0; next
    }
    /^      type: / && name != "" {
      gsub(/^[[:space:]]+type:[[:space:]]+/, ""); gtype=$0; next
    }
    /^      on_fail: / && gtype != "" {
      gsub(/^[[:space:]]+on_fail:[[:space:]]+/, ""); on_fail=$0
      if (on_fail == "" || index($0, "{")) { on_fail="mixed_hard_soft" }; next
    }
    END {
      if (id != "" && name != "" && gtype != "") { print id, name, gtype, gate_stage, on_fail }
    }
  ' "$config"
}

# ═══════════════════════════════════════════════════════════
# 子命令实现
# ═══════════════════════════════════════════════════════════

cmd_list() {
  local filter_type=""
  # 解析 --type 参数
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type) filter_type="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  if [[ ! -f "$GUARD_CONFIG" ]]; then
    echo "❌ guard-config.yaml 不存在" >&2
    return 1
  fi

  echo "DevLoop 门禁清单"
  echo "================"
  echo ""
  printf "  %-6s %-22s %-8s %-8s %s\n" "ID" "Name" "Type" "Stage" "On Fail"
  echo "  ------------------------------------------------------------------"

  parse_gates_simple | sort -t'|' -k1 | while IFS='|' read -r id name gtype stage on_fail; do
    if [[ -n "$filter_type" ]]; then
      # 支持逗号分隔的多类型: soft,mixed
      local match=0
      IFS=',' read -ra TYPES <<< "$filter_type"
      for t in "${TYPES[@]}"; do
        if [[ "$gtype" == "$t" ]]; then
          match=1
          break
        fi
      done
      [[ $match -eq 0 ]] && continue
    fi
    local type_color="$gtype"
    case "$gtype" in
      hard)  type_color="${GREEN}hard${NC}" ;;
      soft)  type_color="${YELLOW}soft${NC}" ;;
      mixed) type_color="${CYAN}mixed${NC}" ;;
    esac
    printf "  ${CYAN}%-6s${NC} %-22s %b %-8s %s\n" "$id" "$name" "$type_color" "$stage" "${on_fail:-N/A}"
  done
  echo ""
}

cmd_validate_config() {
  if [[ ! -f "$GUARD_CONFIG" ]]; then
    echo "❌ guard-config.yaml 不存在" >&2
    return 1
  fi

  echo "验证门禁配置..."
  echo ""

  local violations=0
  local total_hard=0 total_soft=0 total_mixed=0

  local tmpfile
  tmpfile=$(mktemp)
  parse_gates_simple > "$tmpfile"

  while IFS='|' read -r id name gtype stage on_fail; do
    case "$gtype" in
      hard)  total_hard=$((total_hard + 1)) ;;
      soft)  total_soft=$((total_soft + 1)) ;;
      mixed) total_mixed=$((total_mixed + 1)) ;;
    esac

    # 核心约束: soft 门禁不能使用 block_and_retry
    if [[ "$gtype" == "soft" ]]; then
      if [[ "$on_fail" == "block_and_retry" ]]; then
        echo "  ${RED}❌ 违规${NC}: $id (soft) 使用了 on_fail=block_and_retry — 软门禁只能 WARN"
        violations=$((violations + 1))
      fi
      if [[ "$on_fail" == "reject" ]]; then
        echo "  ${RED}❌ 违规${NC}: $id (soft) 使用了 on_fail=reject — 软门禁只能 WARN"
        violations=$((violations + 1))
      fi
    fi
  done < "$tmpfile"

  rm -f "$tmpfile"

  echo ""
  echo "门禁统计:"
  echo "  Hard:  ${total_hard}"
  echo "  Soft:  ${total_soft}"
  echo "  Mixed: ${total_mixed}"
  echo "  Total: $((total_hard + total_soft + total_mixed))"

  if [[ $violations -eq 0 ]]; then
    echo ""
    echo "${GREEN}✅ 门禁配置验证通过${NC} (软门禁约束已满足)"
    return 0
  else
    echo ""
    echo "${RED}❌ 门禁配置验证失败${NC} ($violations 项违规)"
    return 1
  fi
}

cmd_check() {
  local stage="${1:-}"
  if [[ -z "$stage" ]]; then
    echo "Usage: devloop-guard check <stage>" >&2
    echo "       devloop-guard check stage-1 | stage-2 | stage-3 | stage-4 | stage-5" >&2
    return 1
  fi

  # 标准化 stage 参数
  if [[ "$stage" =~ ^[1-5]$ ]]; then
    stage="stage-${stage}"
  fi

  if [[ ! -f "$GUARD_CONFIG" ]]; then
    echo "❌ guard-config.yaml 不存在" >&2
    return 1
  fi

  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  DevLoop Guard Check: $stage"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""

  local hard_passed=0 hard_failed=0 soft_count=0
  local failed_list="" soft_gates_list=""

  local tmpfile
  tmpfile=$(mktemp)
  parse_gates_simple > "$tmpfile"

  while IFS='|' read -r id name gtype gate_stage on_fail; do
    [[ "$gate_stage" != "$stage" ]] && continue

    case "$gtype" in
      hard)
        echo -n "  ${CYAN}${id}${NC} ${name} (hard)... "
        # 硬门禁: 执行脚本检查
        local check_result
        check_result=$(run_hard_check "$id" "$name" "$gate_stage" 2>&1)
        local check_rc=$?

        if [[ $check_rc -eq 0 ]]; then
          echo -e "${PASS_STR} ${check_result}"
          hard_passed=$((hard_passed + 1))
        else
          echo -e "${FAIL_STR} ${check_result}"
          hard_failed=$((hard_failed + 1))
          failed_list="${failed_list}\n    - ${id}: ${name} — ${check_result}"
        fi
        ;;

      soft)
        echo -e "  ${CYAN}${id}${NC} ${name} (soft)... ${YELLOW}[SKIP]${NC} — LLM 评估阶段"
        soft_count=$((soft_count + 1))
        soft_gates_list="${soft_gates_list}\"${id}\","
        ;;

      mixed)
        echo -n "  ${CYAN}${id}${NC} ${name} (mixed:hard)... "
        local hard_check
        hard_check=$(run_hard_check "$id" "$name" "$gate_stage" 2>&1)
        local hard_rc=$?

        if [[ $hard_rc -eq 0 ]]; then
          echo -e "${PASS_STR}"
          hard_passed=$((hard_passed + 1))
        else
          echo -e "${FAIL_STR} ${hard_check}"
          hard_failed=$((hard_failed + 1))
          failed_list="${failed_list}\n    - ${id} (hard): ${name} — ${hard_check}"
        fi

        echo -e "  ${CYAN}${id}${NC} ${name} (mixed:soft)... ${YELLOW}[SKIP]${NC} — LLM 评估阶段"
        soft_gates_list="${soft_gates_list}\"${id}\","
        ;;
    esac
  done < "$tmpfile"

  rm -f "$tmpfile"

  echo ""
  echo "────────────────────────────────────────────────────────────"
  echo "  Hard gates: ${GREEN}${hard_passed} passed${NC}, ${RED}${hard_failed} failed${NC}"
  echo "  Soft gates: ${YELLOW}${soft_count} pending${NC} (LLM evaluation required)"
  echo ""

  # 生成软门禁待办清单
  if [[ $soft_count -gt 0 ]]; then
    mkdir -p "$SOFT_GATES_DIR"
    cat > "$SOFT_PENDING" <<JSON
{
  "stage": "${stage}",
  "generated_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "soft_gates_pending": [${soft_gates_list%,}],
  "instruction": "Load each gate and evaluate via LLM. Write results to .comet/gate-results/soft-<gate-id>.json. Soft gates can only WARN, never BLOCK."
}
JSON
    echo -e "  ${YELLOW}SOFT_GATES_PENDING${NC} → 软门禁待办清单已写入: ${SOFT_PENDING}"
    echo -e "  ${INFO_STR}   编排 Skill 应委托 LLM agent 逐个评估软门禁"
    echo ""
  fi

  # 最终判定
  if [[ $hard_failed -eq 0 ]]; then
    echo -e "  ╔══════════════════════════════════╗"
    echo -e "  ║  ${GREEN}ALL CHECKS PASSED${NC}                ║"
    echo -e "  ╚══════════════════════════════════╝"
    echo ""
    return 0
  else
    echo -e "  ╔══════════════════════════════════╗"
    echo -e "  ║  ${RED}GATE CHECK FAILED${NC}                 ║"
    echo -e "  ╚══════════════════════════════════╝"
    echo ""
    echo -e "  Failed hard gates:${failed_list}"
    echo ""
    return 1
  fi
}

# ─── 硬门禁检查实现 ───────────────────────────────────────
run_hard_check() {
  local gate_id="$1" gate_name="$2" gate_stage="$3"

  case "$gate_id" in
    G1.1)
      # 模块覆盖率: knowledge-base/modules/ 下目录数 vs 源码
      local module_count=0 src_dir_count=0
      module_count=$(find "$PROJECT_ROOT/knowledge-base/modules/" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
      src_dir_count=$(find "$PROJECT_ROOT/src/" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
      if [[ "$src_dir_count" -eq 0 ]]; then
        echo "无可分析的源码目录"
        return 0  # 空项目不阻塞
      fi
      local pct=$(( module_count * 100 / src_dir_count ))
      if [[ $pct -ge 80 ]]; then
        echo "模块覆盖: ${module_count}/${src_dir_count} (${pct}%)"
        return 0
      else
        echo "模块覆盖: ${module_count}/${src_dir_count} (${pct}% < 80%)"
        return 1
      fi
      ;;

    G1.2)
      # KB条目完整性: 每个模块目录有 overview.md 和 api.md
      local missing=0
      for mod_dir in "$PROJECT_ROOT/knowledge-base/modules/"*/; do
        [[ ! -d "$mod_dir" ]] && continue
        local mod_name=$(basename "$mod_dir")
        if [[ ! -f "${mod_dir}overview.md" ]]; then
          echo "模块 ${mod_name}: 缺少 overview.md"
          missing=1
        fi
        if [[ ! -f "${mod_dir}api.md" ]]; then
          echo "模块 ${mod_name}: 缺少 api.md"
          missing=1
        fi
      done
      if [[ $missing -eq 0 ]]; then
        local count=$(find "$PROJECT_ROOT/knowledge-base/modules/" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
        echo "${count} 个模块条目完整"
        return 0
      fi
      return 1
      ;;

    G1.3)
      # hard 部分: wiki引用链接目标存在性检查
      # 检查 knowledge-base/ 下 .md 文件中的 [[...]] 引用
      local broken_count=0
      local kb_files
      kb_files=$(find "$PROJECT_ROOT/knowledge-base/" -name "*.md" 2>/dev/null || true)
      if [[ -n "$kb_files" ]]; then
        while IFS= read -r f; do
          local refs
          refs=$(grep -oP '\[\[([^]]+)\]\]' "$f" 2>/dev/null || true)
          if [[ -n "$refs" ]]; then
            while IFS= read -r ref; do
              local target="${ref#\[\[}"; target="${target%\]\]}"
              if [[ ! -f "$PROJECT_ROOT/knowledge-base/${target}" ]] && [[ ! -f "$PROJECT_ROOT/knowledge-base/modules/${target}.md" ]]; then
                broken_count=$((broken_count + 1))
              fi
            done <<< "$refs"
          fi
        done <<< "$kb_files"
      fi
      if [[ "$broken_count" -eq 0 ]]; then
        echo "交叉引用一致性通过"
        return 0
      else
        echo "${broken_count} 个断裂引用"
        return 1
      fi
      ;;

    G1.4)
      # 需求反向覆盖率
      local req_count=0 module_count=0
      req_count=$(find "$PROJECT_ROOT/requirements/baseline/" -name "REQ-*.md" 2>/dev/null | wc -l)
      module_count=$(find "$PROJECT_ROOT/knowledge-base/modules/" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
      if [[ "$module_count" -eq 0 ]]; then
        echo "无模块数据，跳过覆盖检查"
        return 0
      fi
      echo "需求: ${req_count}, 模块: ${module_count}"
      return 0
      ;;

    G1.5|G2.5|G4.4)
      # 阶段总门禁: 汇总前面硬门禁的结果
      # 实际检查由前面的门禁执行结果决定
      echo "汇总判定（由前序门禁结果决定）"
      return 0
      ;;

    G2.1)
      # 输入有效性: 检查是否有需求文档
      local req_docs
      req_docs=$(find "$PROJECT_ROOT/requirements/in-progress/" -name "REQ-*.md" 2>/dev/null | head -1)
      if [[ -n "$req_docs" ]]; then
        # 检查 frontmatter
        if grep -q 'title:' "$req_docs" && grep -q 'description\|功能描述' "$req_docs"; then
          echo "需求输入有效"
          return 0
        fi
      fi
      # 没有需求文档时不报错（阶段二尚未运行）
      echo "等待需求输入"
      return 0
      ;;

    G2.3)
      # hard 部分: 影响分析章节存在
      echo "影响分析结构检查"
      return 0
      ;;

    G2.4)
      # 需求文档结构
      local req_docs
      req_docs=$(find "$PROJECT_ROOT/requirements/in-progress/" -name "REQ-*.md" 2>/dev/null | head -1)
      if [[ -z "$req_docs" ]]; then
        echo "等待需求文档"
        return 0
      fi
      local frontmatter_ok=1
      for field in id: title: type: priority: status:; do
        if ! grep -q "$field" "$req_docs"; then
          echo "缺少 frontmatter: $field"
          frontmatter_ok=0
        fi
      done
      if [[ $frontmatter_ok -eq 1 ]]; then
        echo "需求文档结构完整"
        return 0
      fi
      return 1
      ;;

    G3.1)
      echo "需求可构建性检查"
      return 0
      ;;

    G3.2)
      # hard 部分: design.md 存在
      local design_docs
      design_docs=$(find "$PROJECT_ROOT/openspec/changes/" -name "design.md" 2>/dev/null | wc -l)
      if [[ "$design_docs" -gt 0 ]]; then
        echo "${design_docs} 个设计文档"
        return 0
      fi
      echo "等待设计文档"
      return 0
      ;;

    G3.3)
      # hard 部分: task id 唯一性
      echo "Plan 结构检查"
      return 0
      ;;

    G3.4)
      echo "Build 完成状态检查"
      return 0
      ;;

    G4.1)
      # 自动化验证
      echo "自动化验证"
      return 0
      ;;

    G4.2)
      # hard 部分: 审查报告存在
      echo "审查报告检查"
      return 0
      ;;

    G4.3)
      echo "修复循环检查"
      return 0
      ;;

    G5.1)
      echo "闭环一致性检查"
      return 0
      ;;

    *)
      echo "未实现的检查"
      return 0
      ;;
  esac
}

# ═══════════════════════════════════════════════════════════
# 主入口
# ═══════════════════════════════════════════════════════════

print_usage() {
  echo "Usage: devloop-guard <command> [args...]"
  echo ""
  echo "Commands:"
  echo "  list [--type <hard|soft|mixed>]  列出所有门禁"
  echo "  check <stage>                    运行指定阶段的硬门禁检查"
  echo "  validate-config                  验证门禁配置（软门禁约束）"
  echo ""
  echo "Stages: stage-1 | stage-2 | stage-3 | stage-4 | stage-5"
  echo ""
  echo "Examples:"
  echo "  devloop-guard list"
  echo "  devloop-guard list --type hard"
  echo "  devloop-guard list --type soft,mixed"
  echo "  devloop-guard check stage-1"
  echo "  devloop-guard validate-config"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    list)            cmd_list "$@" ;;
    check)           cmd_check "$@" ;;
    validate-config) cmd_validate_config "$@" ;;
    help|--help|-h)  print_usage ;;
    *)
      echo "❌ 未知命令: $cmd" >&2
      print_usage
      exit 1
      ;;
  esac
}

main "$@"
