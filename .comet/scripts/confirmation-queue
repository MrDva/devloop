#!/usr/bin/env bash
# confirmation-queue — 确认队列管理
# 管理 loop-state.yaml 中的 pending_confirmations
# 依赖: bash 4.x, grep, sed, awk
# 用法: confirmation-queue <command> [args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
STATE_FILE="$PROJECT_ROOT/.comet/loop-state.yaml"
DEFAULT_TIMEOUT_HOURS=72  # 默认 72 小时超时

# ─── 颜色 ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

now_iso() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

# ─── 内部: 读取 YAML 列表项 ─────────────────────────────────
# 从 pending_confirmations 块提取所有条目
# 输出格式: idx|type|req|message|timestamp (每行一条)
parse_pending_items() {
  if [[ ! -f "$STATE_FILE" ]]; then
    echo ""
    return
  fi

  # 使用 grep + sed 逐条提取，比 awk 更可靠
  local in_list=false count=0
  local type="" req="" msg="" ts=""

  while IFS= read -r line; do
    # 检测是否进入 pending_confirmations 块
    if echo "$line" | grep -q '^  pending_confirmations:'; then
      in_list=true
      continue
    fi

    # 离开列表区域
    if $in_list && echo "$line" | grep -qE '^  [a-z]' && ! echo "$line" | grep -qE '^    -|^      '; then
      in_list=false
      continue
    fi

    $in_list || continue

    # 解析条目
    if echo "$line" | grep -q '^    - type:'; then
      # 如果有前一条记录，先输出
      if [[ -n "$type" && -n "$req" ]]; then
        echo "${count}|${type}|${req}|${msg}|${ts}"
      fi
      count=$((count + 1))
      type=$(echo "$line" | sed 's/^[[:space:]]*- type:[[:space:]]*//' | tr -d '"')
      req=""; msg=""; ts=""
    elif echo "$line" | grep -q '^      req:'; then
      req=$(echo "$line" | sed 's/^[[:space:]]*req:[[:space:]]*//' | tr -d '"')
    elif echo "$line" | grep -q '^      message:'; then
      msg=$(echo "$line" | sed 's/^[[:space:]]*message:[[:space:]]*//' | tr -d '"')
    elif echo "$line" | grep -q '^      timestamp:'; then
      ts=$(echo "$line" | sed 's/^[[:space:]]*timestamp:[[:space:]]*//' | tr -d '"')
    fi
  done < "$STATE_FILE"

  # 输出最后一条
  if [[ -n "$type" && -n "$req" ]]; then
    echo "${count}|${type}|${req}|${msg}|${ts}"
  fi
}

# ─── 内部: 获取 pending 条目数量 ───────────────────────────
pending_count() {
  if [[ ! -f "$STATE_FILE" ]]; then
    echo "0"
    return
  fi
  grep -c 'type:' "$STATE_FILE" 2>/dev/null | tr -d '[:space:]' || echo "0"
}

# ─── 内部: 检查超时 ────────────────────────────────────────
check_item_timeout() {
  local timestamp="$1" timeout_hours="${2:-$DEFAULT_TIMEOUT_HOURS}"
  [[ -z "$timestamp" ]] && { echo "unknown"; return; }

  local ts_sec now_sec
  ts_sec=$(date -d "$timestamp" +%s 2>/dev/null || echo "0")
  now_sec=$(date +%s)

  if [[ "$ts_sec" -eq 0 ]]; then
    echo "unknown"
    return
  fi

  local elapsed_hours
  elapsed_hours=$(( (now_sec - ts_sec) / 3600 ))

  if [[ $elapsed_hours -ge $timeout_hours ]]; then
    echo "timed_out"
  elif [[ $elapsed_hours -ge $(( timeout_hours / 2 )) ]]; then
    echo "warning"
  else
    echo "ok"
  fi
}

# ═══════════════════════════════════════════════════════════════
# 子命令实现
# ═══════════════════════════════════════════════════════════════

cmd_list() {
  if [[ ! -f "$STATE_FILE" ]]; then
    echo "No confirmation queue — state file not found"
    return 0
  fi

  local pcount
  pcount=$(pending_count)

  echo "Confirmation Queue"
  echo "=================="
  echo ""

  if [[ "$pcount" -eq 0 ]]; then
    echo "  (empty — no pending confirmations)"
    return 0
  fi

  echo "  Total pending: ${pcount}"
  echo ""

  while IFS='|' read -r idx type req msg timestamp; do
    local timeout_status
    timeout_status=$(check_item_timeout "$timestamp")
    local status_icon=""
    case "$timeout_status" in
      timed_out) status_icon="${RED}⏰ TIMED OUT${NC}" ;;
      warning)   status_icon="${YELLOW}⏳ EXPIRING${NC}" ;;
      ok)        status_icon="${GREEN}✓${NC}" ;;
      *)         status_icon="${CYAN}?${NC}" ;;
    esac

    printf "  ${CYAN}[%s]${NC} %-10s ${YELLOW}%s${NC} — %s\n" "$idx" "[${type}]" "$req" "$msg"
    echo "       Status: ${status_icon} | Created: ${timestamp:-unknown}"
    echo ""
  done < <(parse_pending_items)
}

cmd_show() {
  local idx="${1:-}"
  if [[ -z "$idx" ]]; then
    echo "Usage: confirmation-queue show <index>" >&2
    return 1
  fi

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "No confirmation queue — state file not found"
    return 1
  fi

  local found=false
  while IFS='|' read -r item_idx type req msg timestamp; do
    if [[ "$item_idx" == "$idx" ]]; then
      found=true
      echo "Confirmation Item #${idx}"
      echo "========================"
      echo ""
      echo "  Type:      ${type}"
      echo "  Request:   ${req}"
      echo "  Message:   ${msg}"
      echo "  Created:   ${timestamp:-unknown}"
      echo "  Timeout:   $(check_item_timeout "$timestamp")"
      echo ""
      # 如果有关联的需求文件，显示 path
      local req_file
      req_file=$(find "$PROJECT_ROOT/requirements" -name "${req}*.md" 2>/dev/null | head -1)
      if [[ -n "$req_file" ]]; then
        echo "  Related:   ${req_file#$PROJECT_ROOT/}"
        echo ""
      fi
      break
    fi
  done < <(parse_pending_items)

  if ! $found; then
    echo "❌ Item #${idx} not found"
    return 1
  fi
}

cmd_confirm() {
  local idx="${1:-}"
  if [[ -z "$idx" ]]; then
    echo "Usage: confirmation-queue confirm <index>" >&2
    return 1
  fi

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "❌ State file not found"
    return 1
  fi

  # 找到并移除指定条目
  local item_line
  item_line=$(grep -n 'type:' "$STATE_FILE" | sed -n "${idx}p" | cut -d: -f1)

  if [[ -z "$item_line" ]]; then
    echo "❌ Item #${idx} not found"
    return 1
  fi

  # 获取条目信息用于确认输出
  local type req msg
  type=$(sed -n "${item_line}p" "$STATE_FILE" | sed 's/.*type:[[:space:]]*//' | tr -d '"')
  req=$(sed -n "$((item_line + 1))p" "$STATE_FILE" | sed 's/.*req:[[:space:]]*//' | tr -d '"')
  msg=$(sed -n "$((item_line + 2))p" "$STATE_FILE" | sed 's/.*message:[[:space:]]*//' | tr -d '"')

  # 移除该条目（从 type 到 timestamp 共 4 行）
  local tmp="${STATE_FILE}.tmp.$$"
  sed "${item_line},$((item_line + 3))d" "$STATE_FILE" > "$tmp"

  # 检查是否 pending_confirmations 变空了
  if ! grep -q 'type:' "$tmp"; then
    # 清理空列表标记
    echo "  📋 Queue is now empty"
  fi

  mv "$tmp" "$STATE_FILE"

  echo "✅ Confirmed: [${type}] ${req} — ${msg}"
}

cmd_reject() {
  local idx="${1:-}" reason="${2:-}"
  if [[ -z "$idx" ]]; then
    echo "Usage: confirmation-queue reject <index> [reason]" >&2
    return 1
  fi

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "❌ State file not found"
    return 1
  fi

  local item_line
  item_line=$(grep -n 'type:' "$STATE_FILE" | sed -n "${idx}p" | cut -d: -f1)

  if [[ -z "$item_line" ]]; then
    echo "❌ Item #${idx} not found"
    return 1
  fi

  local type req msg timestamp
  type=$(sed -n "${item_line}p" "$STATE_FILE" | sed 's/.*type:[[:space:]]*//' | tr -d '"')
  req=$(sed -n "$((item_line + 1))p" "$STATE_FILE" | sed 's/.*req:[[:space:]]*//' | tr -d '"')
  msg=$(sed -n "$((item_line + 2))p" "$STATE_FILE" | sed 's/.*message:[[:space:]]*//' | tr -d '"')
  timestamp=$(sed -n "$((item_line + 3))p" "$STATE_FILE" | sed 's/.*timestamp:[[:space:]]*//' | tr -d '"')

  # 移除该条目
  local tmp="${STATE_FILE}.tmp.$$"
  sed "${item_line},$((item_line + 3))d" "$STATE_FILE" > "$tmp"

  # 记录到 errors
  local ts
  ts=$(now_iso)
  local error_entry="    - type: rejection\\n      req: ${req}\\n      message: \"Rejected: ${msg}\"\\n      reason: \"${reason:-no reason provided}\"\\n      timestamp: \"${ts}\""
  if grep -q "errors:" "$tmp"; then
    sed -i "/errors:/a\\${error_entry}" "$tmp"
  fi

  mv "$tmp" "$STATE_FILE"

  echo "❌ Rejected: [${type}] ${req} — ${msg}"
  [[ -n "$reason" ]] && echo "   Reason: ${reason}"
}

cmd_skip() {
  local idx="${1:-}"
  if [[ -z "$idx" ]]; then
    echo "Usage: confirmation-queue skip <index>" >&2
    return 1
  fi

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "❌ State file not found"
    return 1
  fi

  local item_line
  item_line=$(grep -n 'type:' "$STATE_FILE" | sed -n "${idx}p" | cut -d: -f1)

  if [[ -z "$item_line" ]]; then
    echo "❌ Item #${idx} not found"
    return 1
  fi

  local type req msg
  type=$(sed -n "${item_line}p" "$STATE_FILE" | sed 's/.*type:[[:space:]]*//' | tr -d '"')
  req=$(sed -n "$((item_line + 1))p" "$STATE_FILE" | sed 's/.*req:[[:space:]]*//' | tr -d '"')
  msg=$(sed -n "$((item_line + 2))p" "$STATE_FILE" | sed 's/.*message:[[:space:]]*//' | tr -d '"')

  # 移除该条目（跳过 = 移除但不记录错误）
  local tmp="${STATE_FILE}.tmp.$$"
  sed "${item_line},$((item_line + 3))d" "$STATE_FILE" > "$tmp"
  mv "$tmp" "$STATE_FILE"

  echo "⏭️  Skipped: [${type}] ${req} — ${msg}"
}

cmd_batch_confirm() {
  local filter_type="${1:-all}"

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "❌ State file not found"
    return 1
  fi

  local total
  total=$(pending_count)

  if [[ "$total" -eq 0 ]]; then
    echo "No pending confirmations"
    return 0
  fi

  echo "Batch confirming ${total} item(s)..."
  echo ""

  # 从后往前删除（避免索引偏移）
  for ((i = total; i >= 1; i--)); do
    if [[ "$filter_type" == "all" ]]; then
      cmd_confirm "$i" > /dev/null
    else
      # 检查类型匹配
      local item_type
      item_type=$(grep -n 'type:' "$STATE_FILE" | sed -n "${i}p" | sed 's/.*type:[[:space:]]*//' | tr -d '"')
      if [[ "$item_type" == "$filter_type" ]]; then
        cmd_confirm "$i" > /dev/null
      fi
    fi
  done

  echo "✅ Batch confirm complete — $(pending_count) remaining"
}

cmd_check_timeout() {
  local timeout_hours="${1:-$DEFAULT_TIMEOUT_HOURS}"

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "No state file — nothing to check"
    return 0
  fi

  local pcount timed_out=0 warning=0
  pcount=$(pending_count)

  echo "Timeout Check (threshold: ${timeout_hours}h)"
  echo "============================================="
  echo ""

  if [[ "$pcount" -eq 0 ]]; then
    echo "  (no pending items)"
    return 0
  fi

  while IFS='|' read -r idx type req msg timestamp; do
    local status
    status=$(check_item_timeout "$timestamp" "$timeout_hours")

    case "$status" in
      timed_out)
        echo -e "  ${RED}[TIMED OUT]${NC} #${idx}: [${type}] ${req}"
        echo "       ${msg}"
        echo "       Created: ${timestamp}"
        echo ""
        ;;
      warning)
        echo -e "  ${YELLOW}[EXPIRING]${NC}  #${idx}: [${type}] ${req}"
        echo "       ${msg}"
        echo "       Created: ${timestamp}"
        echo ""
        ;;
    esac
  done < <(parse_pending_items)
}

# ═══════════════════════════════════════════════════════════════
# 主入口
# ═══════════════════════════════════════════════════════════════

print_usage() {
  echo "Usage: confirmation-queue <command> [args...]"
  echo ""
  echo "Commands:"
  echo "  list                         List all pending confirmations"
  echo "  show <index>                 Show details of a specific item"
  echo "  confirm <index>              Confirm (approve) an item — removes it"
  echo "  reject <index> [reason]      Reject an item — removes and logs to errors"
  echo "  skip <index>                 Skip an item — removes without logging"
  echo "  batch-confirm [type]         Confirm all items (optionally filtered by type)"
  echo "  check-timeout [hours]        Check for timed-out items"
  echo ""
  echo "Examples:"
  echo "  confirmation-queue list"
  echo "  confirmation-queue show 1"
  echo "  confirmation-queue confirm 1"
  echo "  confirmation-queue reject 2 \"Design needs revision\""
  echo "  confirmation-queue batch-confirm"
  echo "  confirmation-queue check-timeout 48"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    list)           cmd_list "$@" ;;
    show)           cmd_show "$@" ;;
    confirm)        cmd_confirm "$@" ;;
    reject)         cmd_reject "$@" ;;
    skip)           cmd_skip "$@" ;;
    batch-confirm)  cmd_batch_confirm "$@" ;;
    check-timeout)  cmd_check_timeout "$@" ;;
    help|--help|-h) print_usage ;;
    *)
      echo "❌ 未知命令: $cmd" >&2
      print_usage
      exit 1
      ;;
  esac
}

main "$@"
