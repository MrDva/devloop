#!/usr/bin/env bash
# kb-trust-update — KB 信任级别评估
# 扫描所有 KB 条目 frontmatter → 计算 trust level → 检测阻断条件
# 依赖: bash 4.x, grep, sed, awk
# 用法: kb-trust-update [--verbose]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
KB_DIR="$PROJECT_ROOT/knowledge-base"
DRIFT_REPORT="$KB_DIR/.drift-report.yaml"
MANIFEST="$KB_DIR/.manifest.yaml"
TRUST_REPORT="$KB_DIR/.trust-report.yaml"

VERBOSE=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --verbose|-v) VERBOSE=true; shift ;;
    *) shift ;;
  esac
done

# ─── 颜色 ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

now_iso() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

# ─── 内部: 读取 frontmatter 字段 ───────────────────────────
fm_get() {
  local file="$1" field="$2"
  awk -v f="$field" '
    BEGIN { in_fm=0 }
    /^---$/ { if (in_fm==0) { in_fm=1; next } else { exit } }
    in_fm==1 && $1 ~ "^"f":" {
      sub(/^[^:]+:[[:space:]]*/, ""); gsub(/^"|"$/, ""); print; exit
    }
    END { if (in_fm==0 && NR==0) print "" }
  ' "$file" 2>/dev/null
}

# ─── 内部: 计算天数差 ──────────────────────────────────────
days_since() {
  local iso_date="$1"
  [[ -z "$iso_date" || "$iso_date" == "N/A" ]] && { echo "999"; return; }

  local date_sec now_sec
  date_sec=$(date -d "$iso_date" +%s 2>/dev/null || echo "0")
  now_sec=$(date +%s)
  if [[ "$date_sec" -eq 0 ]]; then
    echo "999"
  else
    echo $(( (now_sec - date_sec) / 86400 ))
  fi
}

# ─── 内部: 读取漂移分数 ────────────────────────────────────
get_drift_score() {
  local mod_name="$1"
  local score=0.0

  # 优先从 drift report 读取
  if [[ -f "$DRIFT_REPORT" ]]; then
    local drift_pct
    drift_pct=$(awk -v m="$mod_name" '
      /^  - module:/ { in_entry=0 }
      $0 ~ "^  - module: \"" m "\"" { in_entry=1 }
      in_entry && /drift_percent:/ { gsub(/^.*drift_percent:[[:space:]]*/, ""); print; exit }
    ' "$DRIFT_REPORT" 2>/dev/null || echo "")

    if [[ -n "$drift_pct" ]]; then
      score=$(awk "BEGIN { printf \"%.2f\", $drift_pct / 100 }")
      echo "$score"
      return
    fi
  fi

  # 回退: 从 KB frontmatter 读取
  local fm_score
  fm_score=$(fm_get "$KB_DIR/modules/$mod_name/overview.md" "drift_score" 2>/dev/null || echo "")
  [[ -n "$fm_score" && "$fm_score" != "N/A" ]] && score="$fm_score"

  echo "$score"
}

# ═══════════════════════════════════════════════════════════════
# 信任级别计算
# ═══════════════════════════════════════════════════════════════

# 计算单个 KB 条目的信任级别
# 输入: confidence, drift_score, source, days_old
# 输出: trusted | cautious | untrusted
calculate_trust() {
  local confidence="$1" drift_score="$2" source="$3" days_old="$4"

  # 阻断条件
  # 1. drift_score >= 0.7 → untrusted
  if [[ "$(echo "$drift_score >= 0.7" | bc -l 2>/dev/null || echo 0)" == "1" ]]; then
    echo "untrusted"
    return
  fi

  # 2. confidence == low AND age > 30 days → untrusted
  if [[ "$confidence" == "low" && "$days_old" -gt 30 ]]; then
    echo "untrusted"
    return
  fi

  # 3. source == auto-generated AND drift_score >= 0.3 → cautious
  if [[ "$source" == "auto-generated" ]] && [[ "$(echo "$drift_score >= 0.3" | bc -l 2>/dev/null || echo 0)" == "1" ]]; then
    echo "cautious"
    return
  fi

  # 4. confidence == low → cautious
  if [[ "$confidence" == "low" ]]; then
    echo "cautious"
    return
  fi

  # 5. drift_score >= 0.3 → cautious
  if [[ "$(echo "$drift_score >= 0.3" | bc -l 2>/dev/null || echo 0)" == "1" ]]; then
    echo "cautious"
    return
  fi

  # 6. age > 90 days → cautious
  if [[ "$days_old" -gt 90 ]]; then
    echo "cautious"
    return
  fi

  # 默认: trusted
  echo "trusted"
}

# ═══════════════════════════════════════════════════════════════
# 主逻辑
# ═══════════════════════════════════════════════════════════════

main() {
  local start_ts
  start_ts=$(now_iso)

  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  KB Trust Update — 知识库信任级别评估"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""

  # ── 收集所有需要评估的文件 ──
  local files=()

  # KB 模块条目
  if [[ -d "$KB_DIR/modules" ]]; then
    while IFS= read -r f; do
      files+=("$f")
    done < <(find "$KB_DIR/modules" -name "*.md" -type f 2>/dev/null)
  fi

  # KB 全局文档
  for f in "$KB_DIR/architecture/"*.md "$KB_DIR/apis/"*.md "$KB_DIR/data-models/"*.md; do
    [[ -f "$f" ]] && files+=("$f")
  done

  # 需求文档
  for d in baseline in-progress completed; do
    if [[ -d "$KB_DIR/../requirements/$d" ]]; then
      while IFS= read -r f; do
        files+=("$f")
      done < <(find "$KB_DIR/../requirements/$d" -name "*.md" -type f 2>/dev/null)
    fi
  done

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "  ${YELLOW}⚠ No KB entries found — nothing to evaluate${NC}"

    cat > "$TRUST_REPORT" <<YAML
# KB Trust Report
# Generated: ${start_ts}
# Note: No KB entries exist yet.

generated_at: "${start_ts}"
generated_by: kb-trust-update
total_entries: 0
trust_summary:
  trusted: 0
  cautious: 0
  untrusted: 0
blocking_conditions: []
entries: []
YAML
    echo ""
    echo "✅ Trust report generated (empty)"
    return 0
  fi

  # ── 评估每个文件 ──
  local trusted=0 cautious=0 untrusted=0
  local entries_yaml=""
  local blocking_list=""
  local now_ts
  now_ts=$(now_iso)

  for file in "${files[@]}"; do
    local fname rel_path
    fname=$(basename "$file")
    rel_path="${file#$PROJECT_ROOT/}"

    # 提取 frontmatter
    local confidence source last_updated
    confidence=$(fm_get "$file" "confidence")
    source=$(fm_get "$file" "source")
    last_updated=$(fm_get "$file" "last_updated")

    # 默认值
    [[ -z "$confidence" ]] && confidence="medium"
    [[ -z "$source" ]] && source="unknown"
    [[ -z "$last_updated" ]] && last_updated="unknown"

    # 获取漂移分数
    local drift_score=0.0
    # 确定所属模块名
    local mod_name=""
    if [[ "$file" == "$KB_DIR/modules/"* ]]; then
      mod_name=$(echo "$rel_path" | sed 's|knowledge-base/modules/||' | cut -d'/' -f1)
      drift_score=$(get_drift_score "$mod_name")
    fi

    # 计算天数
    local days_old=0
    if [[ "$last_updated" != "unknown" ]]; then
      days_old=$(days_since "$last_updated")
    fi

    # 计算信任级别
    local trust_level
    trust_level=$(calculate_trust "$confidence" "$drift_score" "$source" "$days_old")

    case "$trust_level" in
      trusted)   trusted=$((trusted + 1)) ;;
      cautious)  cautious=$((cautious + 1)) ;;
      untrusted) untrusted=$((untrusted + 1)) ;;
    esac

    # 阻断条件记录
    if [[ "$trust_level" == "untrusted" ]]; then
      local reason=""
      if [[ "$(echo "$drift_score >= 0.7" | bc -l 2>/dev/null || echo 0)" == "1" ]]; then
        reason="drift_score ${drift_score} exceeds 0.7 threshold"
      elif [[ "$confidence" == "low" && "$days_old" -gt 30 ]]; then
        reason="low confidence (${confidence}) + stale (${days_old} days)"
      else
        reason="trust level critically low"
      fi
      blocking_list="${blocking_list}  - entry: \"${rel_path}\""$'\n'"    trust_level: \"${trust_level}\""$'\n'"    reason: \"${reason}\""$'\n'"    action: \"Review and update KB entry or re-run devloop-reverse\""$'\n'
    fi

    # 条目 YAML
    entries_yaml="${entries_yaml}  - file: \"${rel_path}\""$'\n'"    module: \"${mod_name:-N/A}\""$'\n'"    confidence: \"${confidence}\""$'\n'"    source: \"${source}\""$'\n'"    drift_score: ${drift_score}"$'\n'"    days_since_update: ${days_old}"$'\n'"    trust_level: \"${trust_level}\""$'\n'"    last_updated: \"${last_updated}\""$'\n'"    evaluated_at: \"${now_ts}\""$'\n'

    $VERBOSE && echo "  ${trust_level:0:1} ${rel_path} (conf:${confidence} drift:${drift_score} age:${days_old}d)"
  done

  # ── 生成报告 ──
  cat > "$TRUST_REPORT" <<YAML
# KB Trust Report
# Generated by kb-trust-update at ${start_ts}
# Evaluates trustworthiness of each KB entry based on:
#   - confidence (frontmatter)
#   - drift_score (from kb-drift-check)
#   - source (auto-generated vs manual)
#   - age (days since last_updated)
# trust_level: trusted → cautious → untrusted (blocking)

generated_at: "${start_ts}"
generated_by: kb-trust-update
total_entries: ${#files[@]}
trust_summary:
  trusted: ${trusted}
  cautious: ${cautious}
  untrusted: ${untrusted}
blocking_conditions:
${blocking_list:-  []}
entries:
${entries_yaml}
YAML

  echo ""
  echo "────────────────────────────────────────────────────────────"
  echo "  Trust Summary:"
  echo "    ${GREEN}Trusted:   ${trusted}${NC}"
  echo "    ${YELLOW}Cautious:  ${cautious}${NC}"
  echo "    ${RED}Untrusted: ${untrusted}${NC}"
  echo ""

  if [[ $untrusted -gt 0 ]]; then
    echo -e "  ${RED}⚠ BLOCKING CONDITIONS DETECTED (${untrusted} entries untrusted)${NC}"
    echo "  → Review untrusted entries and update or re-run devloop-reverse"
    echo ""
  else
    echo -e "  ${GREEN}✅ No blocking conditions — all entries at cautious or above${NC}"
    echo ""
  fi

  echo "✅ Trust report written: ${TRUST_REPORT}"
}

main "$@"
